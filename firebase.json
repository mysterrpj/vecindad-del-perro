{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "dev-server.js",
      ".firebaserc",
      ".gitignore",
      "firebase-debug.log",
      "functions",
      "functions/**",
      "*.md",
      "*.pdf",
      ".git",
      ".git/**",
      ".firebase",
      ".firebase/**",
      ".agent",
      ".agent/**",
      "**/node_modules/**",
      "**/.git/**",
      "**/.firebase/**",
      "**/.agent/**",
      "**/.*"
    ]
  }
}
